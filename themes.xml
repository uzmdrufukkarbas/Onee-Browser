<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.OneeBrowser" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Renkler -->
        <item name="colorPrimary">@color/accent</item>
        <item name="colorOnPrimary">@color/bg_primary</item>
        <item name="colorPrimaryContainer">@color/accent_dim</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/bg_toolbar</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>

        <!-- Durum çubuğu -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:enforceStatusBarContrast" tools:ignore="NewApi">false</item>

        <!-- Yazı tipi rengi -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <!-- Karanlık dialog teması -->
    <style name="DarkDialogTheme" parent="Theme.Material3.Dark.Dialog.Alert">
        <item name="android:background">@color/dialog_bg</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

</resources>

<resources xmlns:tools="http://schemas.android.com/tools">
</resources>
