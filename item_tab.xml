<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent" android:layout_height="wrap_content" android:background="?attr/selectableItemBackground" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="12dp" android:paddingBottom="12dp">
    <View android:id="@+id/activeIndicator" android:layout_width="3dp" android:layout_height="0dp" android:background="#4488ff" android:visibility="invisible" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
    <TextView android:id="@+id/tvTabTitle" android:layout_width="0dp" android:layout_height="wrap_content" android:textColor="#ffffff" android:textSize="14sp" android:ellipsize="end" android:maxLines="1" android:paddingStart="12dp" app:layout_constraintStart_toEndOf="@id/activeIndicator" app:layout_constraintEnd_toStartOf="@id/btnCloseTab" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toTopOf="@id/tvTabUrl"
        tools:ignore="RtlSymmetry" />
    <TextView android:id="@+id/tvTabUrl" android:layout_width="0dp" android:layout_height="wrap_content" android:textColor="#666666" android:textSize="11sp" android:ellipsize="end" android:maxLines="1" android:paddingStart="12dp" app:layout_constraintStart_toEndOf="@id/activeIndicator" app:layout_constraintEnd_toStartOf="@id/btnCloseTab" app:layout_constraintTop_toBottomOf="@id/tvTabTitle" app:layout_constraintBottom_toBottomOf="parent"
        tools:ignore="RtlSymmetry" />

    <ImageButton
        android:id="@+id/btnCloseTab"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:alpha="0.5"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/KAPAT"
        android:padding="6dp"
        android:src="@drawable/ic_close"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="TouchTargetSizeCheck" />
</androidx.constraintlayout.widget.ConstraintLayout>